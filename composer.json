{
    "name": "switon/crypto",
    "description": "Symmetric encryption, derived keys, plaintext validation, and key rotation for Switon Framework",
    "type": "library",
    "keywords": [
        "switon",
        "crypto",
        "encryption",
        "openssl",
        "keys"
    ],
    "homepage": "https://github.com/switon-php/crypto",
    "license": "MIT",
    "authors": [
        {
            "name": "switon",
            "email": "admin@switon.dev"
        }
    ],
    "support": {
        "source": "https://github.com/switon-php/crypto",
        "issues": "https://github.com/switon-php/crypto/issues",
        "docs": "https://docs.switon.dev/latest/crypto"
    },
    "require": {
        "php": ">=8.3",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "switon/cli": "^1.0",
        "switon/core": "^1.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "switon/testing": "^1.0",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "allow-plugins": {
            "switon/composer-extra": true,
            "phpstan/extension-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "Switon\\Crypto\\": "src/"
        }
    },
    "autoload-dev": {
        "files": [
            "tests/openssl-overrides.php"
        ],
        "psr-4": {
            "Switon\\Crypto\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpstan": "@php vendor/bin/phpstan analyse",
        "test:unit": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=unit --display-deprecations --display-phpunit-notices",
        "test": "@php vendor/bin/phpunit --configuration tests/phpunit.xml.dist --testsuite=all --display-deprecations --display-phpunit-notices"
    },
    "extra": {
        "switon": {
            "commands": [
                "Switon\\Crypto\\Command\\KeyCommand"
            ]
        },
        "branch-alias": {
            "dev-dev": "1.0.x-dev"
        }
    }
}
